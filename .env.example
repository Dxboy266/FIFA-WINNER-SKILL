# ── API Keys（此文件不会被提交到 Git）──
# 复制此文件为 .env 并填入你的 key：
#   cp .env.example .env

# football-data.org (免费, https://www.football-data.org/ → My Account)
FOOTBALL_DATA_API_KEY=your_key_here

# API-Football via RapidAPI (免费每天100次, https://www.api-football.com/)
API_FOOTBALL_KEY=your_key_here

# The Odds API (免费每月500次, https://the-odds-api.com/)
THE_ODDS_API_KEY=your_key_here
